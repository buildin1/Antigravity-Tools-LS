+                                        if !thought_part.is_empty() {
+                                            let chunks = M::map_delta(model_name, crate::mappers::CascadeDelta::Thinking(thought_part.to_string()), false, tc_buf, in_tc, tc_idx).await?;
+                                            for chunk in chunks { let _ = tx.send(chunk).await; }
